{
  "name": "handshake-solana-wallet",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bunx --bun vite dev",
    "dev:surfnet": "VECTOR_PROGRAM=EMeHQpaeoU3NN679YimZWVxvaSeWqDHMKafcDxGWGRrY BUN_PUBLIC_SOLANA_LOCALNET_RPC_URL=http://127.0.0.1:8899 bunx --bun vite dev",
    "start": "bunx --bun vite preview",
    "surfnet": "NO_DNA=1 surfpool start --offline --artifacts-path ./target/deploy --yes --no-tui --db .surfpool/surfnet.sqlite --surfnet-id handshake-local --airdrop-keypair-path ~/.config/solana/id.json",
    "surfnet:deploy-vector": "solana program deploy --url http://127.0.0.1:8899 --program-id target/deploy/vector_ed25519-keypair.json target/deploy/vector_ed25519.so",
    "surfnet:seed": "VECTOR_PROGRAM=EMeHQpaeoU3NN679YimZWVxvaSeWqDHMKafcDxGWGRrY bun ./scripts/seed-surfnet-tokens.ts",
    "build": "bunx --bun vite build",
    "typecheck": "bunx --bun tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@noble/curves": "^2.2.0",
    "@noble/hashes": "^2.2.0",
    "@orpc/client": "^1.14.5",
    "@orpc/server": "^1.14.5",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@solana/kit": "^6.9.0",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "3.0.0-rc.1",
    "@tanstack/react-router": "^1.170.15",
    "@tanstack/react-start": "^1.168.25",
    "@vitejs/plugin-react": "^6.0.2",
    "@wallet-standard/app": "^1.1.1",
    "@wallet-standard/features": "^1.1.1",
    "@wallet-ui/react": "^4.2.0",
    "@wallet-ui/tailwind": "^4.2.0",
    "buffer": "^6.0.3",
    "bun-plugin-tailwind": "^0.1.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^0.545.0",
    "pg": "^8.16.3",
    "react": "^19",
    "react-dom": "^19",
    "tailwind-merge": "^3.3.1",
    "vite": "^8.0.16",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/bun": "latest",
    "@types/pg": "^8.15.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "tailwindcss": "^4.1.11",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3"
  }
}
